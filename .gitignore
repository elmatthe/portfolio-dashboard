# Python
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
backend/venv/
backend/__pycache__/

# PyInstaller artifacts (regenerated by build script)
backend-dist/
build/
build-shim/
*.spec
backend.spec

# Frontend artifacts
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo
electron/node_modules/

# Top-level staging dir used by electron-builder
dist/

# Packaged installers
release/

# Runtime DB / user data
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Secrets / local env config
.env
.env.local
.env.*
!.env.example

# Claude Code local state (per-machine settings)
.claude/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.local
*.log

# Diagnostic scripts (one-off, never commit). Keep the 7za shim which the
# build script depends on.
_*.py
!scripts/_7za_shim.py

# Test transaction fixtures — broker exports that should not be committed
# (they're synthetic but contain account numbers we don't want in git).
test-transaction-reports/

# Test artefacts
.pytest_cache/
tests/__pycache__/
